# Backend API URL
EXPO_PUBLIC_API_URL=http://192.168.0.106:5000/api

# Google OAuth Client IDs
# Create these at https://console.cloud.google.com/apis/credentials
# For Expo Go development, you need to create OAuth 2.0 Client IDs for:
# - Web application (for Expo proxy auth)
# - Android (for native Android app)
# - iOS (for native iOS app)

EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your-android-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_EXPO_CLIENT_ID=your-expo-client-id.apps.googleusercontent.com

# Instructions for setting up Google OAuth:
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create a new project or select existing one
# 3. Enable Google+ API
# 4. Create OAuth 2.0 Client IDs:
#    - For WEB: Set authorized redirect URIs to: https://auth.expo.io/@your-expo-username/kiosk-mobile-app
#    - For Android: Get SHA-1 fingerprint using: keytool -keystore ~/.android/debug.keystore -list -v
#    - For iOS: Set bundle identifier
# 5. Copy the client IDs to this file
