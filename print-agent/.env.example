# WebSocket URL of the backend server
WS_URL=wss://api.brgybiluso.me

# Must match backend PRINT_AGENT_SECRET exactly
# You can use either AGENT_SECRET or PRINT_AGENT_SECRET key here.
AGENT_SECRET=replace-with-your-server-print-agent-secret

# Alternative key name (same value as AGENT_SECRET)
# PRINT_AGENT_SECRET=replace-with-your-server-print-agent-secret
